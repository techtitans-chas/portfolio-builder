# ── Frontend ──────────────────────────────────────────────────────────────────
NUXT_PORT=3000
# Public API URL used by the browser (and SSR when NUXT_API_URL is not set)
NUXT_PUBLIC_API_URL=http://localhost:3111
# Server-side API URL used during SSR — set to Docker service name in containers,
# or same as NUXT_PUBLIC_API_URL on Render (both use the public backend URL)
# NUXT_API_URL=http://backend:3111
FRONTEND_URL=http://localhost:3000

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=3111
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=<generate-with: openssl rand -base64 32>
# Local dev: http://localhost:3111
# Production: your backend's public URL, e.g. https://portfolio-builder-backend.onrender.com
BETTER_AUTH_URL=http://localhost:3111
# Optional — leave blank to disable email sending (e.g. email verification)
RESEND_API_KEY=<your-resend-api-key>

# ── PostgreSQL (local Docker only) ────────────────────────────────────────────
# These are used by docker-compose to initialise the local Postgres container.
# On Render, DATABASE_URL is injected automatically — these vars are not needed.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=portfolio_builder

# Database connection string
# Local (host): use port 5433 (Docker maps container 5432 → host 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/portfolio_builder
# Local (inside Docker network): postgresql://postgres:postgres@postgres:5432/portfolio_builder
# Render: injected automatically from the managed database — do not set manually

# ── Cloudflare R2 (file uploads) ──────────────────────────────────────────────
# Optional — leave all blank to disable file upload support.
# Setup: create a bucket in Cloudflare R2, then generate an API token with
# Object Read & Write permissions.
# R2_ACCOUNT_ID    — R2 overview page in the Cloudflare dashboard
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY — from the API token you created
# R2_BUCKET_NAME   — name of your R2 bucket
# R2_PUBLIC_URL    — public URL for your bucket, e.g. https://pub-<hash>.r2.dev
R2_ACCOUNT_ID=<your-cloudflare-account-id>
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_BUCKET_NAME=portfolio-builder
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# ── GitHub Actions / Docker Hub (CI/CD only — do not set locally) ─────────────
# These are configured as GitHub repository secrets, not in .env.
# Documented here for reference only.
#
# DOCKER_USERNAME               — Docker Hub username
# DOCKER_PASSWORD               — Docker Hub access token (Settings → Security → New Access Token)
# RENDER_DEPLOY_HOOK_BACKEND    — Render deploy hook URL for the backend service
# RENDER_DEPLOY_HOOK_FRONTEND   — Render deploy hook URL for the frontend service
