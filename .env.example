# Frontend
NUXT_PUBLIC_API_URL=http://localhost:3111
# Server-side API URL used during SSR — set to Docker service name when running in containers
# NUXT_API_URL=http://backend:3111
FRONTEND_URL=http://localhost:3000

# Backend
PORT=3111
BETTER_AUTH_SECRET=<generate-with: openssl rand -base64 32>
BETTER_AUTH_URL=http://localhost:3111
RESEND_API_KEY=<your-resend-api-key>

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=portfolio_builder

# Database URL — use port 5433 when connecting from host (Docker maps 5432 → 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/portfolio_builder

# Cloudflare R2 (S3-compatible object storage for file uploads)
# Create a bucket in Cloudflare R2, then generate an API token with Object Read & Write permissions.
# R2_ACCOUNT_ID  — found on the R2 overview page in the Cloudflare dashboard
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY — from the API token you created
# R2_BUCKET_NAME  — the name of your R2 bucket
# R2_PUBLIC_URL   — the public URL for your bucket, e.g. https://pub-<hash>.r2.dev
R2_ACCOUNT_ID=<your-cloudflare-account-id>
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_BUCKET_NAME=portfolio-builder
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
