{
  "name": "@portfolio-builder/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared types and schemas for portfolio-builder",
  "exports": {
    "./types": {
      "types": "./types/index.ts",
      "default": "./dist/types/index.js"
    },
    "./schemas": {
      "types": "./schemas/index.ts",
      "default": "./dist/schemas/index.js"
    }
  },
  "files": [
    "types",
    "schemas",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
